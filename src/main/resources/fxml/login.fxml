<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="520.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controllers.LoginController">
    <top>
        <VBox prefHeight="140.0" prefWidth="520.0" style="-fx-background-color: #0f1724; -fx-alignment: center;" BorderPane.alignment="CENTER">
            <children>
                <Label text="⚓ BattleShip" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-text-fill: white;" />
                <Label text="Online Naval Combat" style="-fx-font-size: 14; -fx-font-family: 'Segoe UI'; -fx-text-fill: #94a3b8;" />
            </children>
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="18.0" style="-fx-background-color: #ffffff;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Welcome Back" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI';" />

                <VBox spacing="8.0" prefWidth="340.0">
                    <children>
                        <Label text="Username" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #475569; -fx-font-family: 'Segoe UI';" />
                        <TextField fx:id="loginField" promptText="Enter your username" style="-fx-padding: 14 16; -fx-font-size: 14; -fx-font-family: 'Segoe UI'; -fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1.5; -fx-text-fill: #1e293b;" />
                    </children>
                </VBox>

                <VBox spacing="8.0" prefWidth="340.0">
                    <children>
                        <Label text="Password" style="-fx-font-size: 13; -fx-font-weight: 600; -fx-text-fill: #475569; -fx-font-family: 'Segoe UI';" />

                        <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-padding: 14 16; -fx-font-size: 14; -fx-font-family: 'Segoe UI'; -fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1.5; -fx-text-fill: #1e293b;" />

                        <TextField fx:id="visiblePasswordField" promptText="Enter your password" visible="false" managed="false" style="-fx-padding: 14 16; -fx-font-size: 14; -fx-font-family: 'Segoe UI'; -fx-background-color: #ffffff; -fx-border-color: #d1d5db; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1.5; -fx-text-fill: #1e293b;" />

                        <CheckBox fx:id="showPasswordCheckBox" text="Show password" style="-fx-font-size: 13; -fx-text-fill: #475569; -fx-font-family: 'Segoe UI'; -fx-padding: 6 0;" />
                    </children>
                </VBox>

                <Label fx:id="statusLabel" textFill="#ef4444" style="-fx-font-size: 14; -fx-font-family: 'Segoe UI'; -fx-padding: 6 0;" wrapText="true" />

                <Button fx:id="loginButton" onAction="#handleLogin" prefHeight="48.0" prefWidth="340.0" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-padding: 10; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-family: 'Segoe UI';" text="Sign In" />

                <HBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label text="First time here?" style="-fx-font-size: 14; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI';" />
                        <Hyperlink fx:id="registerLink" onAction="#handleRegister" text="Register" style="-fx-font-size: 14; -fx-text-fill: #c9a84c; -fx-font-weight: bold; -fx-underline: true; -fx-font-family: 'Segoe UI';" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>